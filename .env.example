# Configuración de Ejemplo para la Aplicación
# Copia este archivo a .env.local y actualiza con tus valores

# Modo de desarrollo
REACT_APP_ENV=development

# URL de la API (cuando sea implementada)
# REACT_APP_API_URL=http://localhost:5000

# Puerto (opcional, por defecto 3000)
# PORT=3000

# Variables de autenticación (cuando sea implementada)
# REACT_APP_AUTH_TOKEN=

# Variables de base de datos (cuando sea implementada)
# REACT_APP_DB_URL=
